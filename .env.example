# Runtime user/group for bind-mounted data directory ownership
PUID=1000
PGID=1000

# Backend selection
DB_BACKEND=auto
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=postgres
DB_PASSWORD=
DB_SSLMODE=prefer

# SQLite settings (used when DB_BACKEND=sqlite or DB_BACKEND=auto with empty DB_HOST/DB_NAME)
DATA_DIR=/data
SQLITE_DB_PATH=
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_ENABLE_WAL=1
DATA_SYNC_INTERVAL_SECONDS=3600
DATA_SYNC_EXTERNAL_REFRESH_ENABLED=0
DATA_SYNC_EXTERNAL_REFRESH_INTERVAL_SECONDS=86400

# API runtime
IMPORT_MAX_BYTES=10485760
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email
OIDC_REDIRECT_PATH=/api/auth/callback
OIDC_SESSION_SECRET=change-me
OIDC_SESSION_COOKIE=world_tracker_session
OIDC_LOGIN_COOKIE=world_tracker_login
OIDC_SESSION_TTL_SECONDS=604800
OIDC_LOGIN_TTL_SECONDS=600
OIDC_COOKIE_SECURE=0
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_WORKERS=1
